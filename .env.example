# Microsoft Entra ID (Azure AD) Application Credentials
# Obtain these from Azure Portal > App Registrations
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=

# Server Configuration
PORT=5000

# CORS - set to your Vite dev server URL during development
CLIENT_URL=http://localhost:5173

# Client-side env vars (prefix with VITE_ for Vite to expose them to the browser)
VITE_TENANT_ID=
VITE_CLIENT_ID=
